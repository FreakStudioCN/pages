<category name="MAX9814MIC">
  <label text="Library: https://github.com/FreakStudioCN/GraftSense-Drivers-MicroPython "></label>
  <button text="Install max9814mic library" callbackKey="installPyLib"></button>
  
  <label text="MAX9814MIC Module"></label>
  <block type="max9814mic_init">
    <value name="adc_pin">
      <shadow type="pinout">
        <field name="PIN"></field>
      </shadow>
    </value>
    <value name="gain_pin">
      <shadow type="pinout">
        <field name="PIN"></field>
      </shadow>
    </value>
    <value name="shdn_pin">
      <shadow type="pinout">
        <field name="PIN"></field>
      </shadow>
    </value>
  </block>
  <block type="max9814mic_method_read"></block>
  <block type="max9814mic_method_read_normalized"></block>
  <block type="max9814mic_method_read_voltage">
    <value name="vref">
      <shadow type="math_number">
        <field name="NUM">3.3</field>
      </shadow>
    </value>
  </block>
  <block type="max9814mic_method_enable"></block>
  <block type="max9814mic_method_disable"></block>
  <block type="max9814mic_method_set_gain">
    <value name="high">
      <shadow type="logic_boolean">
        <field name="BOOL">FALSE</field>
      </shadow>
    </value>
  </block>
  <block type="max9814mic_method_get_state"></block>
  <block type="max9814mic_method_get_average_reading">
    <value name="samples">
      <shadow type="math_number">
        <field name="NUM">10</field>
      </shadow>
    </value>
  </block>
  <block type="max9814mic_method_get_peak_reading">
    <value name="samples">
      <shadow type="math_number">
        <field name="NUM">100</field>
      </shadow>
    </value>
  </block>
  <block type="max9814mic_method_detect_sound_level">
    <value name="threshold">
      <shadow type="math_number">
        <field name="NUM">35000</field>
      </shadow>
    </value>
    <value name="samples">
      <shadow type="math_number">
        <field name="NUM">50</field>
      </shadow>
    </value>
  </block>
  <block type="max9814mic_method_calibrate_baseline">
    <value name="samples">
      <shadow type="math_number">
        <field name="NUM">100</field>
      </shadow>
    </value>
  </block>
</category>